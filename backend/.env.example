# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5000

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=qr_ordering

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Credentials encryption — used to encrypt each restaurant's Cloudinary
# API secret before it's stored in the database. Must be a 64-character
# hex string (32 bytes). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Losing/changing this key makes all previously-stored Cloudinary secrets
# undecryptable — back it up somewhere safe, separate from the DB backup.
CREDENTIALS_ENCRYPTION_KEY=replace_with_a_64_char_hex_string

# Note: there is no shared/global Cloudinary account anymore — every
# restaurant configures its own Cloudinary credentials (set by the super
# admin at creation time, in the "Create Restaurant" form, or later by
# the restaurant owner under Settings).

# Super admin bootstrap — only used on the very first boot, when no
# super admin account exists yet. Ignored after that (safe to leave set
# or remove either way). This is how you get your first login, since
# there's no public signup for the super admin panel.
SUPER_ADMIN_USERNAME=Aliyu@admin2030
SUPER_ADMIN_PASSWORD=Aliyu@2008
